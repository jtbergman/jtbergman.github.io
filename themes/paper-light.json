{
  "name": "paper-light",
  "type": "light",
  "colors": {
    "editor.background": "#f2efe8",
    "editor.foreground": "#3a352f"
  },
  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#9a9081",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "storage.type",
        "storage.modifier",
        "keyword.other"
      ],
      "settings": {
        "foreground": "#9c3a2b"
      }
    },
    {
      "scope": [
        "string",
        "string.quoted",
        "punctuation.definition.string"
      ],
      "settings": {
        "foreground": "#5f6f3c"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.language.boolean"
      ],
      "settings": {
        "foreground": "#a8631a"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call.generic"
      ],
      "settings": {
        "foreground": "#2f6f6a"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.type",
        "support.class"
      ],
      "settings": {
        "foreground": "#8a5a2f"
      }
    },
    {
      "scope": [
        "variable",
        "variable.other",
        "meta.definition.variable"
      ],
      "settings": {
        "foreground": "#3a352f"
      }
    },
    {
      "scope": [
        "variable.parameter"
      ],
      "settings": {
        "foreground": "#5a5048"
      }
    },
    {
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#7a6f63"
      }
    },
    {
      "scope": [
        "punctuation",
        "meta.brace"
      ],
      "settings": {
        "foreground": "#6e685f"
      }
    },
    {
      "scope": [
        "entity.name.tag"
      ],
      "settings": {
        "foreground": "#9c3a2b"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name",
        "support.type.property-name"
      ],
      "settings": {
        "foreground": "#a8631a"
      }
    },
    {
      "scope": [
        "constant.other.symbol",
        "constant.character",
        "constant.character.escape"
      ],
      "settings": {
        "foreground": "#2f6f6a"
      }
    }
  ]
}